{
  "name": "moyuyo-app",
  "version": "1.0.0",
  "description": "MOYUYO ATELIER - Modern Luxury Pet Lifestyle App，基于 uni-app + WordPress/WooCommerce REST API",
  "private": true,
  "scripts": {
    "dev:h5": "uni",
    "dev:mp-weixin": "uni -p mp-weixin",
    "dev:app": "uni -p app",
    "build:h5": "uni build",
    "build:mp-weixin": "uni build -p mp-weixin",
    "build:app": "uni build -p app",
    "lint": "eslint --ext .js,.vue src/ --fix",
    "format": "prettier --write src/",
    "prepare": "husky install"
  },
  "dependencies": {
    "@dcloudio/uni-app": "^3.0.0-3081220230817001",
    "@dcloudio/uni-app-plus": "^3.0.0-3081220230817001",
    "@dcloudio/uni-components": "^3.0.0-3081220230817001",
    "@dcloudio/uni-h5": "^3.0.0-3081220230817001",
    "@dcloudio/uni-mp-weixin": "^3.0.0-3081220230817001",
    "pinia": "^2.0.36",
    "uview-plus": "^3.3.62",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/eslint-parser": "^7.29.7",
    "@dcloudio/types": "^3.4.0",
    "@dcloudio/uni-automator": "^3.0.0-3081220230817001",
    "@dcloudio/uni-cli-shared": "^3.0.0-3081220230817001",
    "@dcloudio/uni-stacktracey": "^3.0.0-3081220230817001",
    "@dcloudio/vite-plugin-uni": "^3.0.0-3081220230817001",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.33.0",
    "husky": "^8.0.3",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "sass": "^1.69.0",
    "typescript": "^7.0.2",
    "vite": "^4.1.4",
    "vue-eslint-parser": "^10.4.1"
  },
  "lint-staged": {
    "*.{js,vue}": "eslint --fix",
    "*.{js,vue,scss,css,md}": "prettier --write"
  }
}
