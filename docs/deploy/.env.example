# ============================================================
# MOYUYO 环境变量配置文件
# 复制此文件为 .env 并填写实际值
# ============================================================

# --------------------------
# WooCommerce 配置
# --------------------------
WOOCOMMERCE_URL=https://your-woocommerce-store.com
WOOCOMMERCE_CONSUMER_KEY=ck_your_consumer_key_here
WOOCOMMERCE_CONSUMER_SECRET=cs_your_consumer_secret_here

# --------------------------
# Docker 配置
# --------------------------
DOCKER_IMAGE=registry.moyuyo.com/moyuyo-backend
DOCKER_TAG=v1.0.0

# --------------------------
# MySQL 配置
# --------------------------
MYSQL_ROOT_PASSWORD=YOUR_MYSQL_ROOT_PASSWORD
MYSQL_DATABASE=moyuyo_prod
MYSQL_USER=moyuyo
MYSQL_PASSWORD=YOUR_MYSQL_PASSWORD

# --------------------------
# Redis 配置
# --------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# --------------------------
# RocketMQ 配置
# --------------------------
ROCKETMQ_NAME_SERVER=rocketmq-namesrv:9876

# --------------------------
# Spring Boot 配置
# --------------------------
SPRING_PROFILES_ACTIVE=prod

# --------------------------
# 管理后台配置
# --------------------------
ADMIN_EMAIL=admin@moyuyo.com
ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD_AT_LEAST_8_CHARS

# --------------------------
# JWT 配置
# --------------------------
JWT_SECRET=YOUR_JWT_SECRET_KEY_MIN_32_CHARS
JWT_EXPIRE_HOURS=2
JWT_REFRESH_EXPIRE_DAYS=30

# --------------------------
# Stripe 支付配置
# --------------------------
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# --------------------------
# PayPal 配置
# --------------------------
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET
PAYPAL_MODE=sandbox

# --------------------------
# Apple Pay 配置
# --------------------------
APPLE_PAY_MERCHANT_ID=merchant.com.moyuyo
APPLE_PAY_CERT_PATH=/app/certs/apple_pay.p12
APPLE_PAY_CERT_PASSWORD=YOUR_APPLE_PAY_CERT_PASSWORD

# --------------------------
# Google Pay 配置
# --------------------------
GOOGLE_PAY_MERCHANT_ID=YOUR_GOOGLE_PAY_MERCHANT_ID

# --------------------------
# Cloudflare CDN 配置
# --------------------------
CLOUDFLARE_API_KEY=YOUR_CLOUDFLARE_API_KEY
CLOUDFLARE_EMAIL=your@email.com
CLOUDFLARE_ZONE_ID=YOUR_CLOUDFLARE_ZONE_ID

# --------------------------
# AWS S3 配置
# --------------------------
AWS_ACCESS_KEY=YOUR_AWS_ACCESS_KEY
AWS_SECRET_KEY=YOUR_AWS_SECRET_KEY
AWS_S3_REGION=us-west-2
AWS_S3_BUCKET=moyuyo-assets

# --------------------------
# SendGrid 邮件配置
# --------------------------
SENDGRID_API_KEY=SG.YOUR_SENDGRID_API_KEY
SENDGRID_FROM_EMAIL=noreply@moyuyo.com
SENDGRID_FROM_NAME=MOYUYO

# --------------------------
# 应用配置
# --------------------------
APP_URL=https://api.moyuyo.com
FRONTEND_URL=https://www.moyuyo.com
SUPPORT_EMAIL=support@moyuyo.com
CONTACT_EMAIL=contact@moyuyo.com

# --------------------------
# 日志配置
# --------------------------
LOG_LEVEL=INFO
LOG_MAX_SIZE=100MB
LOG_MAX_HISTORY=30

# --------------------------
# 限流配置
# --------------------------
RATE_LIMIT_REQUESTS_PER_SECOND=100
RATE_LIMIT_LOGIN_REQUESTS_PER_MINUTE=60

# --------------------------
# 缓存配置
# --------------------------
CACHE_TTL_MINUTES=30
CACHE_STALE_TTL_MINUTES=5

# --------------------------
# 时区配置
# --------------------------
TZ=Asia/Shanghai
