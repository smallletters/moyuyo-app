<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyuyo.dao.mapper.OrderItemMapper">

  <select id="selectByOrderId" resultType="com.moyuyo.dao.entity.OrderItemEntity">
    SELECT * FROM mo_order_item
    WHERE order_id = #{orderId}
    ORDER BY id ASC
  </select>

</mapper>
